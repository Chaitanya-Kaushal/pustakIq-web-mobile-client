{
  "name": "pustakiq",
  "version": "0.1.0",
  "private": true,
  "description": "PustakIQ — India's hyperlocal education community platform (monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start -w @pustakiq/mobile",
    "mobile:ios": "npm run ios -w @pustakiq/mobile",
    "mobile:android": "npm run android -w @pustakiq/mobile",
    "web": "npm run dev -w @pustakiq/web",
    "web:build": "npm run build -w @pustakiq/web",
    "web:start": "npm run start -w @pustakiq/web",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "build": "turbo run build"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
